{
  "name": "contracts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "forge build",
    "test": "forge test",
    "test:verbose": "forge test -vvv",
    "fmt": "forge fmt",
    "fmt:check": "forge fmt --check",
    "deploy:private": "forge script script/Deploy.s.sol --rpc-url privacy_node --broadcast --legacy",
    "deploy:public": "forge script script/DeployPublic.s.sol --rpc-url public_chain --broadcast --legacy",
    "balance": "forge script script/CheckBalance.s.sol --rpc-url privacy_node"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "@rayls/contracts": "^2.6.3-nightly.2"
  }
}
