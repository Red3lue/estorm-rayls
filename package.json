{
  "name": "estorm-rayls",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "yarn workspace frontend dev",
    "dev:backend": "yarn workspace backend dev",
    "dev": "concurrently \"yarn dev:frontend\" \"yarn dev:backend\"",
    "build:contracts": "yarn workspace contracts build",
    "test:contracts": "yarn workspace contracts test",
    "deploy:contracts:private": "yarn workspace contracts deploy:private",
    "deploy:contracts:public": "yarn workspace contracts deploy:public"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "packageManager": "yarn@4.6.0"
}
