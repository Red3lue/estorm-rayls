{
  "name": "estorm-rayls",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:contracts": "npm run build --workspace=contracts",
    "test:contracts": "npm run test --workspace=contracts",
    "deploy:contracts:private": "npm run deploy:private --workspace=contracts",
    "deploy:contracts:public": "npm run deploy:public --workspace=contracts",
    "agent": "npm run agent --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@openzeppelin/contracts-upgradeable": "^5.4.0"
  },
  "packageManager": "npm@10.9.2"
}
